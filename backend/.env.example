SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
VERIFY_TOKEN=
GROQ_API_KEY=

# Speech-to-Text (WhatsApp voice notes)
# Get a key at https://dashboard.sarvam.ai/
SARVAM_API_KEY=
# sarvam (default, Saaras v3) | groq (Whisper fallback)
STT_PROVIDER=sarvam

PORT=3000

# Auth / WhatsApp welcome
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_WELCOME_TEMPLATE=jaspers_market_order_confirmation_v1
WHATSAPP_WELCOME_LANG=en_US
# Set to false to hide OTP in API responses (needs a real email sender)
AUTH_DEMO_OTP=true
